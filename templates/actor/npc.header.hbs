{{! Sheet Header }}
<header class='npc sheet-header draggable'>
  <div class="npc-header">

    {{!Character Name}}
    <div class="npcNameHeader">
      <div class='header-fields npcName-grid'>
        <div class="bold">{{localize 'AOV.name'}}</div>
        <div class='document-name'><input class="stat-input" name='name' type='text' value='{{actor.name}}' /></div>
        <div class="new-row left" style="padding-top: 10px;">
          {{#if system.beserkerOpt}}
            <a class="{{#unless system.beserkerStat}}fade{{/unless}} secIcon" data-tooltip="{{ localize 'AOV.npcOptions.beserker' }}" data-action="toggleActor" data-property="beserkerStat">
              <i class="mediumIcon fas fa-axe-battle"></i>
            </a>
          {{/if}}

        </div>

        <div class="npc-icons-grid" style="padding-top: 10px;">
          <div class="left">
            <a class="secIcon" data-tooltip="{{ localize 'AOV.expandAll' }}"  data-action="npcSections" data-property="expand"> <i class="mediumIcon fas fa-chevrons-down"></i></a>
            <a class="secIcon" data-tooltip="{{ localize 'AOV.collapseAll' }}"  data-action="npcSections" data-property="collapse"> <i class="mediumIcon fas fa-chevrons-up"></i></a>
          </div>
          <div class="right">
            {{#unless isLocked}}
              <a class="secIcon" data-tooltip="{{ localize 'AOV.TokenCreationRoll.ButtonRoll' }}" data-action="randomStats"> <i class="mediumIcon fas fa-dice"></i></a>
              <a class="secIcon" data-tooltip="{{ localize 'AOV.TokenCreationRoll.ButtonAverage' }}" data-action="averageStats"> <i class="mediumIcon fas fa-scale-balanced"></i> </a>
              <a style="color: transparent; text-shadow:none;"><i class="fas fa-dice"></i></a>
            {{/unless}}
            <a class="tab-toggle secIcon" data-tooltip="{{ localize 'AOV.viewStat' }}"  data-tabval="1"> <i class="mediumIcon fas fas fa-user"></i></a>
            <a class="tab-toggle secIcon" data-tooltip="{{ localize 'AOV.viewBaseStat' }}" data-tabval="3"> <i class="mediumIcon fas fa-user-magnifying-glass"></i></a>
            <a class="note-toggle secIcon" data-tooltip="{{ localize 'AOV.viewNotes' }}" data-tabval="2"> <i class="{{#unless actor.system.noteView}}fade{{/unless}} mediumIcon fas fa-scroll"></i></a>

          </div>
        </div>
      </div>
    </div>

    {{!Logo}}
    <div>
      {{#if showLogo}}
        <img class="img-centre aovlogo">
      {{/if}}
    </div>

    {{!Icons}}
    <div class="right">
      {{#if isLocked}}
        <div><a class="icon15 terIcon" data-action="toggleActor" data-property="locked" data-tooltip='{{localize "AOV.unlock"}}'>
          <i class="fas fa-lock"></i>
        </a></div>
      {{else}}
        <div><a class="icon15 terIcon" data-action="toggleActor" data-property="locked" data-tooltip='{{localize "AOV.lock"}}'>
          <i class="fas fa-lock-open"></i>
        </a></div>
      {{/if}}
      {{#if isLinked}}
        <div><a class="icon15 terIcon" data-tooltip='{{localize "AOV.linked"}}'><i class="fas fa-link"></i></a></div>
      {{else}}
        <div><a class="icon15 terIcon" data-tooltip='{{localize "AOV.unlinked"}}'><i class="fas fa-link-slash"></i></a></div>
      {{/if}}
      {{#if isSynth}}
        <div><a class="icon15 terIcon" data-tooltip='{{localize "AOV.synth"}}'><i class="fas fa-people-group"></i></a></div>
      {{/if}}
    </div>
  </div>


  <div>
    <img class="img-centre aovline">
  </div>

  {{!Tab View 1 - NPC stats}}
  {{#if (eq system.tabView "1")}}
    <div class="npcHeader">
        <div class="npc-stats-grid">
          {{#each system.abilities as |ability key|}}
            <div class="ability-cell bold">{{ability.label}}</div>
            {{#if ../isLocked}}
              <div class="ability-cell centre terIcon rollable bottom-line" data-action="diceroll" data-property="ability" data-characteristic="{{key}}" data-tooltip="AOV.rolls.abilityRoll">{{ability.total}}</div>
            {{else}}
              <div class="ability-cell"><input class="stat-input" name='system.abilities.{{key}}.value' type='text' value='{{ability.value}}' /></div>
            {{/if}}
          {{/each}}
        </div>

        <div class="npc-ability-grid">
          <div class="ability-cell left bold" data-tooltip="{{localize 'AOV.hp'}}">{{localize 'AOV.hpAbbr'}}</div>
          <div class="ability-cell centre terIcon">{{system.hp.value}}</div>
          <div class="ability-cell centre"> / </div>
          <div class="ability-cell centre terIcon">{{system.hp.max}}</div>

          <div class="ability-cell left bold" data-tooltip="{{localize 'AOV.mp'}}">{{localize 'AOV.mpAbbr'}}</div>
          <div class="ability-cell centre terIcon"><input class="stat-input" name='system.mp.value' type='number' value='{{system.mp.value}}' /></div>
          <div class="ability-cell centre"> / </div>
          <div class="ability-cell centre terIcon">{{system.mp.availMax}}</div>

          <div class="ability-cell left bold" data-tooltip="{{localize 'AOV.dmgBonus'}}">{{localize 'AOV.dmgBonusAbbr'}}</div>
          <div class="ability-cell centre terIcon" style="grid-column: 2 / 5;">{{system.dmgBonus}}</div>

          <div class="ability-cell left bold" data-tooltip="{{localize 'AOV.mr'}}">{{localize 'AOV.mrAbbr'}}</div>
          {{#if isLocked}}
            <div class="ability-cell centre terIcon" style="grid-column: 2 / 5;">{{system.movement}}</div>
          {{else}}
            <div class="ability-cell centre terIcon" style="grid-column: 2 / 5;">
              <input class="stat-input" name='system.movement' type='text' value='{{system.movement}}'/>
            </div>
          {{/if}}
        </div>

      {{!Image Section}}
      <div>
        <img class='' src='{{actor.img}}' data-edit='img' data-action='onEditImage' height='75' width='75' />
      </div>
    </div>

    <div>
      <img class="img-centre" src='systems/aov/art-assets/line.png' width="600" />
    </div>


    {{!Hit Locations Section}}
    <ol class='hit-loc-grid'>
      <div class='hit-loc-row primBackCol'>
        <div class="indent hit-loc-cell bold rollable" data-action="toggleActor" data-property="hitlocView">{{localize 'AOV.hitLocation'}}
          {{#if system.hitlocView}}
            <a class='' data-tooltip='{{localize "AOV.collapseSection"}}'><i class='fas fa-chevrons-up'></i></a>
          {{else}}
            <a class='' data-tooltip='{{localize "AOV.expandSection"}}'><i class='fas fa-chevrons-down'></i></a>
          {{/if}}
        </div>
        <div class="centre hit-loc-cell bold">{{localize 'AOV.d20'}}</div>
        <div class="centre hit-loc-cell bold">{{localize 'AOV.armourPointsAbbr'}}</div>
        <div class="centre hit-loc-cell bold">{{localize 'AOV.damageAbbr'}}</div>
        <div class="centre hit-loc-cell bold">{{localize 'AOV.hpAbbr'}}</div>
        <div class="centre hit-loc-cell bold">
          {{#if isLocked}}
            <a data-action="rollHitLoc" data-tooltip="{{localize 'AOV.rollHitLoc'}}"><i class="fas fa-dice-d20"></i></a>
          {{else}}
            <a class='item-control item-create' data-tooltip='{{localize "AOV.createDoc" type=(localize "TYPES.Item.hitloc")}}'
              data-action='createDoc' data-document-class='Item' data-type='hitloc'>
              <i class='fas fa-plus'></i>
            </a>
          {{/if}}
        </div>
      </div>

      {{#if system.hitlocView}}
        {{#each hitLocs as |item id|}}
            <li class='item hit-loc-row' data-item-id='{{item._id}}' data-drag='true' data-document-class='Item'>
              <div class="indent hit-loc-cell rollable" data-action='viewDoc'>{{item.name}}</div>
              {{#if (eq item.system.locType 'general')}}
                <div class="hit-loc-cell"></div>
              {{else}}
                <div class="centre hit-loc-cell terIcon">{{item.system.label}}</div>
              {{/if}}
              {{#if (eq item.system.locType 'general')}}
                  <div class="hit-loc-cell"></div>
              {{else}}
                {{#if ../isLocked}}
                  <div class="centre hit-loc-cell terIcon">{{item.system.npcAP}}</div>
                {{else}}
                  <div class="centre hit-loc-cell skill-inline"><input class="skillDev-input centre" name='system.npcAP'
                    type='number' value='{{item.system.npcAP}}' data-field="npcAP"/></div>
                {{/if}}
              {{/if}}
              <div class="centre hit-loc-cell skill-inline"><input class="skillDev-input centre" name='system.npcDmg'
                type='number' value='{{item.system.npcDmg}}' data-field="npcDmg"/></div>
              {{#if (eq item.system.locType 'general')}}
                <div class="centre hit-loc-cell terIcon"></div>
              {{else}}
                <div class="centre hit-loc-cell terIcon">{{item.system.currHp}} / {{item.system.hpMax}}</div>
              {{/if}}
              <div class='hit-loc-cell gear-controls centre'>
                {{#unless ../isLocked}}
                  <a class='item-delete centre' data-tooltip='{{localize "AOV.deleteDoc" type=(localize "TYPES.Item.hitloc")}}'
                    data-action="deleteDoc">
                    <i class='fas fa-trash'></i>
                  </a>
                {{/unless}}
              </div>
            </li>
          {{/each}}
        {{/if}}
      </ol>

    {{!Skills Section}}
    <ol class='npc-skill-grid'>
      <div class='npc-skill-row primBackCol'>
        <div class="bold indent rollable" data-action="toggleActor" data-property="skillView">{{localize 'AOV.skills'}}
          {{#if system.skillView}}
            <a class='' data-tooltip='{{localize "AOV.collapseSection"}}'><i class='fas fa-chevrons-up'></i></a>
          {{else}}
            <a class='' data-tooltip='{{localize "AOV.expandSection"}}'><i class='fas fa-chevrons-down'></i></a>
          {{/if}}
        </div>
        <div class="centre">%</div>
        <div class="centre">
          {{#if @root.editable}}
            <a class='item-control item-create' data-tooltip='{{localize "AOV.createDoc" type=(localize "TYPES.Item.skill")}}'
              data-action='createDoc' data-document-class='Item' data-type='skill'>
              <i class='fas fa-plus'></i>
            </a>
          {{/if}}
        </div>
      </div>
      {{#if system.skillView}}
        {{#each skills as |item id|}}
            <li class='item npc-skill-row' data-item-id='{{item._id}}' data-drag='true' data-document-class='Item'>
              {{#if ../isLocked}}
                <div class="rollable" data-action='viewDoc'>{{item.name}}</div>
                <div class="centre rollable terIcon" data-action="diceroll" data-property="skill" data-skill-id="{{item._id}}" data-tooltip="AOV.rolls.skillRoll">{{item.system.total}}</div>
              {{else}}
                <div class="skill-inline"><input class="skillDev-input left" name='itemName'
                  type='text' value='{{item.name}}' data-field="itemName"></div>
                <div class="centre skill-inline"><input class="skillDev-input centre" name='system.base'
                  type='number' value='{{item.system.base}}' data-field="base"/></div>
              {{/if}}
              {{#if ../isLocked}}
                <a class='gear-name centre' data-action="itemToggle" data-property="augment">
                  {{#if item.system.augment}}
                    <i data-tooltip="{{localize 'AOV.augmentUsed'}}" class="terIcon fa-solid fa-hand-holding-magic"></i>
                  {{/if}}
                </a>
              {{else}}
                  <a class='item-delete centre' data-tooltip='{{localize "AOV.deleteDoc" type=(localize "TYPES.Item.skill")}}'
                    data-action="deleteDoc">
                    <i class='fas fa-trash'></i>
                  </a>
              {{/if}}
            </div>
          </li>
        {{/each}}
      {{/if}}
    </ol>

    {{!Weapons Section}}
    <ol class='npc-weapon-grid'>
      <div class='npc-weapon-row primBackCol'>
        <div class="bold indent rollable" data-action="toggleActor" data-property="weaponView">{{localize 'TYPES.Item.weapon'}}
          {{#if system.weaponView}}
            <a class='' data-tooltip='{{localize "AOV.collapseSection"}}'><i class='fas fa-chevrons-up'></i></a>
          {{else}}
            <a class='' data-tooltip='{{localize "AOV.expandSection"}}'><i class='fas fa-chevrons-down'></i></a>
          {{/if}}
        </div>
        <div class="centre bold">%</div>
        <div class="centre bold" data-tooltip="{{localize 'AOV.specDamageShow'}}">{{localize 'AOV.damage'}}</div>
        <div class="centre bold">{{localize 'AOV.dmgBonusAbbr'}}</div>
        <div class="centre bold">{{localize 'AOV.hpAbbr'}}</div>
        <div class="centre bold">
          {{#if @root.editable}}
            <a class='item-control item-create' data-tooltip='{{localize "AOV.createDoc" type=(localize "TYPES.Item.weapon")}}'
              data-action='createDoc' data-document-class='Item' data-type='weapon'>
              <i class='fas fa-plus'></i>
            </a>
          {{/if}}
        </div>
      </div>
      {{#if system.weaponView}}
        {{#each weapons as |item id|}}
            <li class='item npc-weapon-row' data-item-id='{{item._id}}' data-drag='true' data-document-class='Item'>
              {{#if ../isLocked}}
                <div class="rollable" data-action='viewDoc'>{{item.name}}</div>
                <div class="centre terIcon rollable" data-action="diceroll" data-property="combat" data-skill-id="{{item._id}}" data-tooltip="AOV.rolls.combatRoll">{{item.system.total}}</div>
                <div class="centre rollable" data-action="diceroll" data-property="damage" data-skill-id="{{item._id}}" data-tooltip="AOV.rolls.damageRoll">{{item.system.damage}}{{#if item.system.special}}*{{/if}}</div>
                <div class="centre" data-tooltip="{{item.system.damTypeLabel}}">{{item.system.dbLabel}}</div>
                <div class="centre npc-weapon-hp">
                  <div class="centre skill-inline"><input class="skillDev-input centre" name='system.currHP'
                    type='number' value='{{item.system.currHP}}' data-field="currHP"/></div>
                  <div class="centre"> / </div>
                  <div class="centre terIcon">{{item.system.maxHP}}</div>
                </div>


              {{else}}
                <div class="skill-inline"><input class="skillDev-input left" name='itemName'
                  type='text' value='{{item.name}}' data-field="itemName"></div>
                <div class="centre skill-inline"><input class="skillDev-input centre" name='system.npcBase'
                  type='number' value='{{item.system.npcBase}}' data-field="npcBase"/></div>
                <div class="centre skill-inline" data-tooltip="{{item.system.damTypeLabel}}"><input class="skillDev-input centre" name='system.damage'
                  type='text' value='{{item.system.damage}}' data-field="damage"/></div>
                <div class="centre">{{item.system.dbLabel}}</div>
                <div class="centre npc-weapon-hp">
                  <div class="centre skill-inline"><input class="skillDev-input centre" name='system.currHP'
                    type='number' value='{{item.system.currHP}}' data-field="currHP"/></div>
                  <div class="ability-cell centre"> / </div>
                  <div class="centre skill-inline"><input class="skillDev-input centre" name='system.maxHP'
                    type='number' value='{{item.system.maxHP}}' data-field="maxHP"/></div>
                </div>

              {{/if}}
              {{#unless ../isLocked}}
                  <a class='item-delete centre' data-tooltip='{{localize "AOV.deleteDoc" type=(localize "TYPES.Item.hitloc")}}'
                    data-action="deleteDoc">
                    <i class='fas fa-trash'></i>
                  </a>
              {{/unless}}
            </div>
          </li>
        {{/each}}
      {{/if}}
    </ol>

    {{!Powers Section}}
    {{#if showPowers}}
      <ol class='npc-weapon-grid'>
        <div class='npc-power-row primBackCol'>
          <div class="bold indent rollable" data-action="toggleActor" data-property="powerView">{{localize 'TYPES.Item.npcpower'}}
            {{#if system.powerView}}
              <a class='' data-tooltip='{{localize "AOV.collapseSection"}}'><i class='fas fa-chevrons-up'></i></a>
            {{else}}
              <a class='' data-tooltip='{{localize "AOV.expandSection"}}'><i class='fas fa-chevrons-down'></i></a>
            {{/if}}
          </div>
          <div class="bold">{{localize 'AOV.description'}}</div>
          <div class="centre bold">
            {{#if @root.editable}}
              <a class='item-control item-create' data-tooltip='{{localize "AOV.createDoc" type=(localize "TYPES.Item.npcpower")}}'
                data-action='createDoc' data-document-class='Item' data-type='npcpower'>
                <i class='fas fa-plus'></i>
              </a>
            {{/if}}
          </div>
        </div>
        {{#if system.powerView}}
          {{#each powers as |item id|}}
              <li class='item npc-power-row' data-item-id='{{item._id}}' data-drag='true' data-document-class='Item'>
                {{#if ../isLocked}}
                  <div class="rollable truncate" data-tooltip="{{item.name}}" data-action='viewDoc'>{{item.name}}</div>
                  <div class="truncate"  data-tooltip="{{item.system.description}}">{{item.system.description}}</div>
                {{else}}
                  <div class="skill-inline"><input class="skillDev-input left" name='itemName'
                    type='text' value='{{item.name}}' data-field="itemName"></div>
                  <div class="skill-inline"><input class="skillDev-input" name='system.powerDescription'
                    type='text' value='{{item.system.description}}' data-field="powerDescription"/></div>
                {{/if}}
                {{#unless ../isLocked}}
                    <a class='item-delete centre' data-tooltip='{{localize "AOV.deleteDoc" type=(localize "TYPES.Item.hitloc")}}'
                      data-action="deleteDoc">
                      <i class='fas fa-trash'></i>
                    </a>
                {{/unless}}
              </div>
            </li>
          {{/each}}
        {{/if}}
      </ol>
    {{/if}}

    {{!Passions Section}}
    {{#if showPassions}}
      <ol class='npc-skill-grid'>
        <div class='npc-skill-row primBackCol'>
          <div class="bold indent rollable" data-action="toggleActor" data-property="passionView">{{localize 'AOV.passions'}}
            {{#if system.passionView}}
              <a class='' data-tooltip='{{localize "AOV.collapseSection"}}'><i class='fas fa-chevrons-up'></i></a>
            {{else}}
              <a class='' data-tooltip='{{localize "AOV.expandSection"}}'><i class='fas fa-chevrons-down'></i></a>
            {{/if}}
          </div>
          <div class="centre">%</div>
          <div class="centre">
            {{#if @root.editable}}
              <a class='item-control item-create' data-tooltip='{{localize "AOV.createDoc" type=(localize "TYPES.Item.passion")}}'
                data-action='createDoc' data-document-class='Item' data-type='passion'>
                <i class='fas fa-plus'></i>
              </a>
            {{/if}}
          </div>
        </div>
        {{#if system.passionView}}
          {{#each passions as |item id|}}
              <li class='item npc-skill-row' data-item-id='{{item._id}}' data-drag='true' data-document-class='Item'>
                {{#if ../isLocked}}
                  <div class="rollable" data-action='viewDoc'>{{item.name}}</div>
                  <div class="centre rollable terIcon" data-action="diceroll" data-property="passion" data-skill-id="{{item._id}}" data-tooltip="AOV.rolls.passionRoll">{{item.system.total}}</div>
                {{else}}
                  <div class="skill-inline"><input class="skillDev-input left" name='itemName'
                    type='text' value='{{item.name}}' data-field="itemName"></div>
                  <div class="centre skill-inline"><input class="skillDev-input centre" name='system.base'
                    type='number' value='{{item.system.base}}' data-field="base"/></div>
                {{/if}}
                {{#if ../isLocked}}
                  <a class='gear-name centre' data-action="itemToggle" data-property="augment">
                    {{#if item.system.augment}}
                      <i data-tooltip="{{localize 'AOV.augmentUsed'}}" class="terIcon fa-solid fa-hand-holding-magic"></i>
                    {{/if}}
                  </a>
                {{else}}
                    <a class='item-delete centre' data-tooltip='{{localize "AOV.deleteDoc" type=(localize "TYPES.Item.passion")}}'
                      data-action="deleteDoc">
                      <i class='fas fa-trash'></i>
                    </a>
                {{/if}}
              </div>
            </li>
          {{/each}}
        {{/if}}
      </ol>
    {{/if}}

    {{!Devotions Section}}
    {{#if showDevotions}}
      <ol class='npc-skill-grid'>
        <div class='npc-skill-row primBackCol'>
          <div class="bold indent rollable" data-action="toggleActor" data-property="devotionView">{{localize 'AOV.devotions'}}
            {{#if system.devotionView}}
              <a class='' data-tooltip='{{localize "AOV.collapseSection"}}'><i class='fas fa-chevrons-up'></i></a>
            {{else}}
              <a class='' data-tooltip='{{localize "AOV.expandSection"}}'><i class='fas fa-chevrons-down'></i></a>
            {{/if}}
          </div>
          <div class="centre">%</div>
          <div class="centre">
            {{#if @root.editable}}
              <a class='item-control item-create' data-tooltip='{{localize "AOV.createDoc" type=(localize "TYPES.Item.devotion")}}'
                data-action='createDoc' data-document-class='Item' data-type='devotion'>
                <i class='fas fa-plus'></i>
              </a>
            {{/if}}
          </div>
        </div>
        {{#if system.devotionView}}
          {{#each devotions as |item id|}}
              <li class='item npc-skill-row' data-item-id='{{item._id}}' data-drag='true' data-document-class='Item'>
                {{#if ../isLocked}}
                  <div class="rollable" data-action='viewDoc'>{{item.name}}</div>
                  <div class="centre terIcon">{{item.system.dp}}</div>
                {{else}}
                  <div class="skill-inline"><input class="skillDev-input left" name='itemName'
                    type='text' value='{{item.name}}' data-field="itemName"></div>
                  <div class="centre skill-inline"><input class="skillDev-input centre" name='system.dp'
                    type='number' value='{{item.system.dp}}' data-field="dp"/></div>
                {{/if}}
                {{#unless ../isLocked}}
                    <a class='item-delete centre' data-tooltip='{{localize "AOV.deleteDoc" type=(localize "TYPES.Item.devotion")}}'
                      data-action="deleteDoc">
                      <i class='fas fa-trash'></i>
                    </a>
                {{/unless}}
              </div>
            </li>
          {{/each}}
        {{/if}}
      </ol>
    {{/if}}



    {{!Gear Section}}
    {{#if showGear}}
      <ol class='npc-skill-grid'>
        <div class='npc-gear-row primBackCol'>
          <div class="bold indent rollable" data-action="toggleActor" data-property="equipView">{{localize 'TYPES.Item.gear'}}
            {{#if system.equipView}}
              <a class='' data-tooltip='{{localize "AOV.collapseSection"}}'><i class='fas fa-chevrons-up'></i></a>
            {{else}}
              <a class='' data-tooltip='{{localize "AOV.expandSection"}}'><i class='fas fa-chevrons-down'></i></a>
            {{/if}}
          </div>
            {{#if @root.editable}}
              <a class='item-control item-create' data-tooltip='{{localize "AOV.createDoc" type=(localize "TYPES.Item.gear")}}'
                data-action='createDoc' data-document-class='Item' data-type='gear'>
                <i class='fas fa-plus'></i>
              </a>
            {{/if}}
          </div>
        </div>
        {{#if system.equipView}}
          {{#each gears as |item id|}}
              <li class='item npc-gear-row' data-item-id='{{item._id}}' data-drag='true' data-document-class='Item'>
                {{#if ../isLocked}}
                  <div class="rollable truncate" data-tooltip="{{item.name}}" data-action='viewDoc'>{{item.name}}</div>
                {{else}}
                  <div class="skill-inline"><input class="skillDev-input left" name='itemName'
                    type='text' value='{{item.name}}' data-field="itemName"></div>
                {{/if}}
                <div>
                  {{#unless ../isLocked}}
                      <a class='item-delete centre' data-tooltip='{{localize "AOV.deleteDoc" type=(localize "TYPES.Item.gear")}}'
                        data-action="deleteDoc">
                        <i class='fas fa-trash'></i>
                      </a>
                  {{/unless}}
                </div>
              </div>
            </li>
          {{/each}}
        {{/if}}
      </ol>
    {{/if}}

    {{!Active Effects Section}}
    {{#if showEffects}}
      <ol class='npc-weapon-grid'>
        <div class="npc-effect-row primBackCol">
          <div class="diff-label indent bold rollable" data-action="toggleActor" data-property="effectView" >{{localize 'Active Effect'}}
              {{#if system.effectView}}
                <a class='' data-tooltip='{{localize "AOV.collapseSection"}}'><i class='fas fa-chevrons-up'></i></a>
              {{else}}
                <a class='' data-tooltip='{{localize "AOV.expandSection"}}'><i class='fas fa-chevrons-down'></i></a>
              {{/if}}
          </div>
          <div class="diff-label centre">{{localize 'AOV.effect'}}</div>
          <div class="diff-label centre">{{localize 'AOV.amount'}}</div>
          <div class="diff-label centre">{{localize 'AOV.active'}}</div>
          <div class="centre">
            <a class="item-control item-create" data-tooltip="{{localize 'SIDEBAR.ACTIONS.CREATE.ActiveEffect'}}" data-action="createEffect">
              <i class="fas fa-plus"></i>
            </a>
          </div>
        </div>
        {{#if system.effectView}}
          {{#each effects as |effect|}}
            <li class="item item-edit npc-effect-row" data-item-id = "{{effect.id}}" data-eff-uuid="{{effect.effUuid}}" data-counter="{{effect.counter}}" {{#if effect.sourceItem}} data-document-class='Item'{{/if}}>
              <div class="effect-source left truncate {{#if effect.sourceItem}}rollable{{/if}}" {{#if effect.sourceItem}} data-tooltip="{{localize 'AOV.viewOnly'}}" data-action="viewDoc" data-preventDel="true"{{/if}}>{{effect.sourceName}}</div>
              <div class="centre truncate" data-tooltip="{{effect.name}}">{{effect.name}}</div>
              <div class="centre">{{effect.value}}</div>
              {{#if effect.isActive}}
                <div class="centre" data-tooltip="{{localize 'AOV.active'}}">
                  <img class="aura-img"  height="18" width="18" />
                </div>
              {{else}}
                <div class="centre" data-tooltip="{{localize 'AOV.inactive'}}">
                  <img class="aura-img fade"  height="18" width="18" />
                </div>
              {{/if}}
              {{#if effect.oneShot}}
                <div class="centre" data-tooltip="{{localize 'AOV.useEffect'}}" data-action="triggerEffects">
                  <a class="centre"><i class="fa-solid fa-bullseye"></i></a>
                </div>
              {{/if}}
            </li>
          {{/each}}
        {{#each actor.effects as |actEffect|}}
            <li class="item item-edit npc-effect-row" data-effect-id="{{actEffect.id}}">
              <div class="effect-source left rollable" data-tooltip="{{localize 'AOV.viewDoc' type=(localize 'DOCUMENT.ActiveEffect')}}" data-action="viewActiveEffect">{{actEffect.name}}</div>
              <div class="centre" data-tooltip="{{#if actEffect.active}}{{localize 'AOV.active'}}{{else}}{{localize 'AOV.inactive'}}{{/if}}">
                <a class="item-control item-create" data-action="toggleEffect">
                  <img class="aura-img{{#unless actEffect.active}} fade{{/unless}}" height="18" width="18" />
                </a>
              </div>
            </li>
          {{/each}}
        {{/if}}
      </ol>
    {{/if}}
  {{/if}}

  {{!Tab View 3 - NPC base stats}}
  {{#if (eq system.tabView "3")}}
    <div class="bold" style="margin: 10px 0px 0px 10px;">{{localize 'AOV.baseStats'}}</div>
    <div class="npc-base-stats-grid">
      <div class="indent primBackCol bold">{{localize 'AOV.characteristics'}}</div>
      <div class="centre primBackCol bold">{{localize 'AOV.roll'}}</div>
      <div class="centre primBackCol bold">{{localize 'AOV.average'}}</div>
      {{#each system.abilities as |ability key|}}
            <div class="ability-cell bold indent" data-characteristic="{{key}}">{{ability.label}}</div>
            {{#if ../isLocked}}
              <div class="npc-stat-display centre">{{ability.formula}}</div>
              <div class="npc-stat-display centre">{{ability.average}}</div>
            {{else}}
              <div class="npc-stat-input"><input class="npc-stat-input" name='system.abilities.{{key}}.formula' type='text' value='{{ability.formula}}' /></div>
              <div class="npc-stat-input"><input class="npc-stat-input" name='system.abilities.{{key}}.average' type='text' value='{{ability.average}}' /></div>
            {{/if}}
          {{/each}}
    </div>
    <br>
    <div class="bold" style="margin: 10px 0px 0px 10px;">{{localize 'AOV.options'}}</div>
    <div class="npc-base-stats-grid">
      <div class="indent">{{localize 'AOV.npcOptions.beserker'}}</div>
      <div class="centre" data-action="toggleActor" data-property="beserkerOpt">
        <a class="icon16">
          <i class="fa-regular {{#if system.beserkerOpt}}fa-square-check{{else}}fa-square{{/if}}"></i>
        </a>
      </div>
      <div class=" new-row indent">{{localize 'AOV.maxHPBonus'}}</div>
      <input class="stat-input" name='system.hp.bonus' type='number' value='{{system.hp.bonus}}'/>
    </div>
  {{/if}}

</header>