<div class="aov settingsForm flexcol" autocomplete="off">
    <h2 class="bold">{{localize 'AOV.Settings.npcSettings'}}</h2>

    <div class="form-group">
      <label class="bold">{{localize 'AOV.Settings.tokenDropMode'}}</label>
      <div class="form-fields" style="flex: 1;">
        <select class="centre" name="tokenDropMode" data-dtype="String">
          {{selectOptions tokenDropModeOptions selected=optSet.tokenDropMode.value}}
        </select>
      </div>
      <p class="settingNote">{{localize 'AOV.Settings.tokenDropModeHint'}}</p>
    </div>

    <br>
    <div class="form-group">
      <label class="bold">{{localize 'AOV.Settings.tokenVariantStatMode'}}</label>
      <div class="form-fields" style="flex: 1;">
        <select class="centre" name="tokenVariantStatMode" data-dtype="String">
          {{selectOptions tokenStatModeOptions selected=optSet.tokenVariantStatMode.value}}
        </select>
      </div>
      <p class="settingNote">{{localize 'AOV.Settings.tokenVariantStatModeHint'}}</p>
    </div>

    <br>
    <div class="form-group">
      <label class="bold">{{localize 'AOV.Settings.tokenVariantSkillMode'}}</label>
      <div class="form-fields" style="flex: 1;">
        <select class="centre" name="tokenVariantSkillMode" data-dtype="String">
          {{selectOptions tokenSkillModeOptions selected=optSet.tokenVariantSkillMode.value}}
        </select>
      </div>
      <p class="settingNote">{{localize 'AOV.Settings.tokenVariantSkillModeHint'}}</p>
    </div>




    <br>
  </div>